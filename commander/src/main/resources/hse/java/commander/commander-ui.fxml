<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="421.0" prefWidth="627.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hse.java.commander.MainController">

    <HBox prefHeight="370.0" prefWidth="627.0">
        <VBox>
            <Label fx:id="leftPathLabel"/>
            <ListView fx:id="leftPane" prefHeight="318.0" prefWidth="311.0"/>
        </VBox>

        <VBox>
            <Label fx:id="rightPathLabel"/>
            <ListView fx:id="rightPane" prefHeight="318.0" prefWidth="321.0"/>
